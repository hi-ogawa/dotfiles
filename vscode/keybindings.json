[
  // Tab navigation (override default Ctrl+Tab quick switcher popup)
  // This aligns with common browser tabs behavior.
  {
    "key": "ctrl+tab",
    "command": "workbench.action.nextEditor"
  },
  {
    "key": "ctrl+shift+tab",
    "command": "workbench.action.previousEditor"
  },

  // Navigate back/forward (this aligns with common browser behavior)
  // Default varies by platform:
  // | Platform | Navigate Back | Navigate Forward |
  // |----------|---------------|------------------|
  // | Windows  | Alt+Left      | Alt+Right        |
  // | Linux    | Ctrl+Alt+-    | Ctrl+Shift+-     |
  // | macOS    | Ctrl+-        | Ctrl+Shift+-     |
  {
    "key": "alt+left",
    "command": "workbench.action.navigateBack",
    "when": "isLinux"
  },
  {
    "key": "alt+right",
    "command": "workbench.action.navigateForward",
    "when": "isLinux"
  },
  // macOS: align with Chrome's Cmd+Left/Right (back/forward).
  // Scoped to editorTextFocus so the override applies only where we want it:
  // the code editor (e.g. after Go to Definition). This overrides the editor's
  // default Cmd+Left/Right (line start/end); use Ctrl+A / Ctrl+E instead.
  // Everything else keeps Cmd+Left/Right for its native meaning: the terminal
  // for shell line editing, and input widgets (find, quick-open, rename) for
  // start/end of the input text.
  {
    "key": "cmd+left",
    "command": "workbench.action.navigateBack",
    "when": "isMac && editorTextFocus"
  },
  {
    "key": "cmd+right",
    "command": "workbench.action.navigateForward",
    "when": "isMac && editorTextFocus"
  },

  // Claude Code terminal newline (shift+enter)
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": { "text": "\\\n" },
    "when": "terminalFocus && !isWindows"
  },
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": { "text": "\u001b\r" },
    "when": "terminalFocus && isWindows"
  },

  // Explorer: Copy Path / Copy Relative Path (align Windows to Linux defaults)
  // Default varies by platform:
  // | Platform | Copy Path    | Copy Relative Path  |
  // |----------|--------------|---------------------|
  // | Windows  | Shift+Alt+C  | Ctrl+K Ctrl+Shift+C |
  // | Linux    | Ctrl+Alt+C   | Ctrl+Shift+Alt+C    |
  {
    "key": "ctrl+alt+c",
    "command": "copyFilePath",
    "when": "isWindows && filesExplorerFocus"
  },
  {
    "key": "ctrl+shift+alt+c",
    "command": "copyRelativeFilePath",
    "when": "isWindows && filesExplorerFocus"
  }

