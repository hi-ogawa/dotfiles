[user]
  name = Hiroshi Ogawa
  email = hi.ogawa.zz@gmail.com
  # https://docs.github.com/en/authentication/managing-commit-signature-verification/telling-git-about-your-signing-key#telling-git-about-your-ssh-key
  signingkey = ~/.ssh/id_ed25519.pub

[alias]
  st = status
  ci = commit
  co = checkout
  br = branch
  lg = log --graph --oneline
  lga = log --graph --oneline --all

  # checkout stack log
  co-lg = "! for ((i=1; i<${1:-10}; i++)); do echo -n \"$i: \"; git rev-parse --symbolic-full-name @{-$i} 2>/dev/null; done && true"
  co-co = "! git checkout @{-${1}} && true"

  # Fetch and merge fast-forward (thus "safe" pull)
  # $ git sfpl <remote=origin>
  sfpl = "! remote=${1:-origin} && branch=$(git rev-parse --abbrev-ref HEAD) && git fetch --no-tags $remote $branch && git merge --ff-only $remote/$branch && true"

  # Start new day: fetch remote and checkout home branch at latest remote main
  # In primary repo: home=main. In linked worktree: home=directory basename (git's default convention).
  # $ git snd <remote-branch=main> <remote=upstream|origin>
  snd = "!f(){ main_wt=$(git worktree list | head -1 | awk '{print $1}'); current=$(git rev-parse --show-toplevel); if [ \"$current\" = \"$main_wt\" ]; then home=main; else home=$(basename \"$current\"); fi; branch=${1:-main}; remote=${2:-}; if [ -z \"$remote\" ]; then git remote get-url upstream >/dev/null 2>&1 && remote=upstream || remote=origin; fi; git fetch --no-tags \"$remote\" \"$branch\" \"$branch:$branch\" && git checkout -B \"$home\" \"$remote/$branch\"; }; f"

  # Start new branch: slugify message into branch name, auto-stage if needed, checkout + commit
  # $ git snb "feat: did something"
  snb = "!f(){ msg=\"$1\"; [ -z \"$msg\" ] && read -rp 'message: ' msg; [ -n \"$msg\" ] || { echo 'usage: git snb \"commit message\"' >&2; return 1; }; branch=$(echo \"$msg\" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]\\+/-/g; s/^-//; s/-$//'); git diff --cached --quiet && git add -A; git checkout -b \"$branch\" && git commit -m \"$msg\"; }; f"

[init]
  defaultBranch = main

[core]
  autocrlf = false
  editor = nano
  excludesfile = ~/.gitignore-global

[color]
  ui = auto

[commit]
  gpgsign = true

[diff]
  tool = vscode

[difftool "vscode"]
  # e.g. git difftool main -- some-path
  cmd = code --wait --diff $LOCAL $REMOTE

[push]
  autoSetupRemote = true

[gpg]
  format = ssh
